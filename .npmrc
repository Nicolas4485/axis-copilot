# Hoist Prisma packages so prisma generate can find @prisma/client from any workspace
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=prisma
# Hoist PostCSS/Tailwind so Next.js can resolve them from postcss.config.js
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=postcss
public-hoist-pattern[]=autoprefixer
