{
  "name": "@axis/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=8192 --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@axis/agents": "workspace:*",
    "@axis/inference": "workspace:*",
    "@axis/ingestion": "workspace:*",
    "@axis/knowledge-graph": "workspace:*",
    "@axis/tools": "workspace:*",
    "@axis/types": "workspace:*",
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.21.0",
    "pdfkit": "^0.15.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.13.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0"
  }
}
