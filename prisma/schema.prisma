generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CONSULTANT
}

enum SessionStatus {
  ACTIVE
  ARCHIVED
  EXPORTED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum StakeholderInfluence {
  HIGH
  MEDIUM
  LOW
}

enum StakeholderInterest {
  HIGH
  MEDIUM
  LOW
}

enum RelationshipType {
  REPORTS_TO
  COLLABORATES
  INFLUENCES
  BLOCKS
}

enum AnalysisType {
  PRODUCT_CRITIQUE
  PROCESS_ANALYSIS
  COMPETITIVE
  STAKEHOLDER_MAP
}

enum SourceType {
  GDRIVE
  UPLOAD
  WEB
  MANUAL
}

enum SyncStatus {
  PENDING
  PROCESSING
  INDEXED
  FAILED
  CONFLICT
}

enum ConflictStatus {
  UNRESOLVED
  RESOLVED_A
  RESOLVED_B
  CUSTOM
}

enum MemoryType {
  EPISODIC
  SEMANTIC
  PROCEDURAL
}

enum IntegrationProvider {
  GOOGLE_DOCS
  GOOGLE_SHEETS
  GMAIL
  GOOGLE_DRIVE
}

enum ExportDestination {
  GDOC
  GSHEET
  EMAIL
  MARKDOWN
  JSON
}

enum AgentTier {
  MICRO
  TASK
  AGENT
}

enum DealStage {
  SOURCING
  SCREENING
  DILIGENCE
  IC_MEMO
  CLOSED_WON
  CLOSED_LOST
  ON_HOLD
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Deal {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  clientId    String    @map("client_id")
  name        String
  stage       DealStage @default(SOURCING)
  priority    Priority  @default(MEDIUM)
  targetClose DateTime? @map("target_close")
  sector      String?
  dealSize    String?   @map("deal_size")
  notes       String?
  assigneeId  String?   @map("assignee_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user      User                @relation(fields: [userId], references: [id])
  client    Client              @relation(fields: [clientId], references: [id])
  sessions  Session[]
  documents KnowledgeDocument[]

  @@index([userId])
  @@index([clientId])
  @@index([stage])
  @@index([createdAt])
  @@map("deals")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  voiceName String   @default("Aoede") @map("voice_name")
  role      UserRole @default(CONSULTANT)
  settings  Json     @default("{}") @map("settings")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  clients            Client[]
  deals              Deal[]
  knowledgeDocs      KnowledgeDocument[]
  agentMemories      AgentMemory[]
  integrations       Integration[]
  conflictRecords    ConflictRecord[]
  costRecords        CostRecord[]
  agentDefinitions   AgentDefinition[]
  outputFeedback     OutputFeedback[]
  pitchDeckTemplates PitchDeckTemplate[]

  @@index([createdAt])
  @@map("users")
}

model Client {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  industry    String?
  companySize Int?     @map("company_size")
  website     String?
  notes       String?
  techStack   Json?    @map("tech_stack")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user            User                @relation(fields: [userId], references: [id])
  sessions        Session[]
  deals           Deal[]
  clientContexts  ClientContext[]
  stakeholders    Stakeholder[]
  analyses        Analysis[]
  knowledgeDocs   KnowledgeDocument[]
  agentMemories   AgentMemory[]
  conflictRecords ConflictRecord[]

  @@index([userId])
  @@index([createdAt])
  @@map("clients")
}

model Session {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  clientId  String?       @map("client_id")
  dealId    String?       @map("deal_id")
  title     String?
  mode      String?
  status    SessionStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id])
  client         Client?         @relation(fields: [clientId], references: [id])
  deal           Deal?           @relation(fields: [dealId], references: [id])
  messages       Message[]
  clientContexts ClientContext[]
  analyses       Analysis[]
  exportRecords  ExportRecord[]
  costRecords    CostRecord[]

  @@index([userId])
  @@index([clientId])
  @@index([dealId])
  @@index([status])
  @@index([createdAt])
  @@map("sessions")
}

model Message {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  role      MessageRole
  content   String
  mode      String?
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
  @@map("messages")
}

model ClientContext {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  sessionId    String   @map("session_id")
  summary      String?
  painPoints   Json     @default("[]") @map("pain_points")
  goals        Json     @default("[]")
  budgetSignal String?  @map("budget_signal")
  createdAt    DateTime @default(now()) @map("created_at")

  client  Client  @relation(fields: [clientId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@index([clientId])
  @@index([sessionId])
  @@map("client_contexts")
}

model Stakeholder {
  id          String               @id @default(cuid())
  clientId    String               @map("client_id")
  name        String
  role        String?
  email       String?
  phone       String?
  influence   StakeholderInfluence @default(MEDIUM)
  interest    StakeholderInterest  @default(MEDIUM)
  department  String?
  reportsToId String?              @map("reports_to_id")
  notes       String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  client    Client       @relation(fields: [clientId], references: [id])
  reportsTo Stakeholder? @relation("StakeholderHierarchy", fields: [reportsToId], references: [id])
  reports   Stakeholder[] @relation("StakeholderHierarchy")

  relationsFrom StakeholderRelation[] @relation("RelationFrom")
  relationsTo   StakeholderRelation[] @relation("RelationTo")

  @@index([clientId])
  @@map("stakeholders")
}

model StakeholderRelation {
  id               String           @id @default(cuid())
  fromId           String           @map("from_id")
  toId             String           @map("to_id")
  relationshipType RelationshipType @map("relationship_type")

  from Stakeholder @relation("RelationFrom", fields: [fromId], references: [id])
  to   Stakeholder @relation("RelationTo", fields: [toId], references: [id])

  @@unique([fromId, toId, relationshipType])
  @@index([fromId])
  @@index([toId])
  @@map("stakeholder_relations")
}

model Analysis {
  id        String       @id @default(cuid())
  sessionId String       @map("session_id")
  clientId  String       @map("client_id")
  type      AnalysisType
  content   Json         @default("{}")
  summary   String?
  createdAt DateTime     @default(now()) @map("created_at")

  session           Session           @relation(fields: [sessionId], references: [id])
  client            Client            @relation(fields: [clientId], references: [id])
  competitorEntries CompetitorEntry[]
  processSteps      ProcessStep[]

  @@index([sessionId])
  @@index([clientId])
  @@index([createdAt])
  @@map("analyses")
}

model CompetitorEntry {
  id          String  @id @default(cuid())
  analysisId  String  @map("analysis_id")
  name        String
  website     String?
  strengths   Json    @default("[]")
  weaknesses  Json    @default("[]")
  features    Json    @default("[]")
  positioning String?

  analysis Analysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@map("competitor_entries")
}

model ProcessStep {
  id                    String  @id @default(cuid())
  analysisId            String  @map("analysis_id")
  stepName              String  @map("step_name")
  automationScore       Int     @map("automation_score")
  agentType             String? @map("agent_type")
  humanCheckpoint       Boolean @default(false) @map("human_checkpoint")
  humanCheckpointReason String? @map("human_checkpoint_reason")
  order                 Int

  analysis Analysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@map("process_steps")
}

model KnowledgeDocument {
  id                String     @id @default(cuid())
  userId            String     @map("user_id")
  clientId          String?    @map("client_id")
  dealId            String?    @map("deal_id")
  title             String
  sourceType        SourceType @map("source_type")
  sourcePath        String?    @map("source_path")
  sourceId          String?    @map("source_id")
  mimeType          String?    @map("mime_type")
  docType           String?    @map("doc_type")
  checksum          String?
  lastSynced        DateTime?  @map("last_synced")
  syncStatus        SyncStatus @default(PENDING) @map("sync_status")
  conflictNotes     String?    @map("conflict_notes")
  chunkCount        Int        @default(0) @map("chunk_count")
  entityCount       Int        @default(0) @map("entity_count")
  attributionMethod String?    @map("attribution_method")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
  deal   Deal?   @relation(fields: [dealId], references: [id])
  chunks DocumentChunk[]

  @@index([userId])
  @@index([clientId])
  @@index([dealId])
  @@index([syncStatus])
  @@index([createdAt])
  @@map("knowledge_documents")
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  content    String
  chunkIndex Int      @map("chunk_index")
  tokens     Int      @default(0)
  metadata   Json     @default("{}")
  /// pgvector: populated by ingestion pipeline — do not write from application code
  embedding  Unsupported("vector(512)")?
  createdAt  DateTime @default(now()) @map("created_at")

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([createdAt])
  @@map("document_chunks")
}

model ConflictRecord {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  clientId   String?        @map("client_id")
  entityName String         @map("entity_name")
  entityType String         @map("entity_type")
  property   String
  valueA     String         @map("value_a")
  valueB     String         @map("value_b")
  sourceDocA String         @map("source_doc_a")
  sourceDocB String         @map("source_doc_b")
  status     ConflictStatus @default(UNRESOLVED)
  resolution String?
  resolvedAt DateTime?      @map("resolved_at")
  resolvedBy String?        @map("resolved_by")
  createdAt  DateTime       @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("conflict_records")
}

model AgentMemory {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  clientId   String?    @map("client_id")
  memoryType MemoryType @map("memory_type")
  content    String
  tags       Json       @default("[]")
  /// pgvector: populated by memory manager — do not write from application code
  embedding  Unsupported("vector(512)")?
  createdAt  DateTime   @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
  @@map("agent_memories")
}

model Integration {
  id           String              @id @default(cuid())
  userId       String              @map("user_id")
  provider     IntegrationProvider
  accessToken  String              @map("access_token")
  refreshToken String?             @map("refresh_token")
  expiresAt    DateTime?           @map("expires_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model ExportRecord {
  id          String            @id @default(cuid())
  sessionId   String            @map("session_id")
  destination ExportDestination
  externalId  String?           @map("external_id")
  externalUrl String?           @map("external_url")
  createdAt   DateTime          @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("export_records")
}

model CostRecord {
  id           String   @id @default(cuid())
  sessionId    String   @map("session_id")
  userId       String   @map("user_id")
  task         String
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  cacheHit     Boolean  @default(false) @map("cache_hit")
  costUsd      Float    @map("cost_usd")
  latencyMs    Int      @map("latency_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
  @@map("cost_records")
}

// ─── Agent Management ──────────────────────────────────────────

model AgentDefinition {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  key              String                          // matches prompt-library key (e.g. AGENT_PRODUCT)
  name             String                          // display name (e.g. "Sean")
  persona          String                          // one-liner persona description
  tier             AgentTier @default(AGENT)
  systemPromptText String    @map("system_prompt_text") @db.Text
  tools            Json      @default("[]")        // string[] of tool names
  mdManifest       String?   @map("md_manifest") @db.Text  // optional .md capability doc
  isBuiltIn        Boolean   @default(false) @map("is_built_in") // system agents can't be deleted
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
  @@index([userId])
  @@index([isActive])
  @@map("agent_definitions")
}

// ─── Audit Log ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")          // null for unauthenticated attempts
  userEmail  String?  @map("user_email")       // denormalised for fast display
  action     String                            // e.g. GET /api/deals/:id
  resource   String                            // e.g. "deal", "document", "memo"
  resourceId String?  @map("resource_id")     // id of the accessed resource
  method     String                            // HTTP method
  path       String                            // full request path
  statusCode Int      @map("status_code")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Output Feedback ───────────────────────────────────────────

model OutputFeedback {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionId    String?  @map("session_id")
  dealId       String?  @map("deal_id")
  agentKey     String   @map("agent_key")     // e.g. AGENT_DUE_DILIGENCE
  outputType   String   @map("output_type")  // e.g. "cim_analysis", "memo_section", "chat"
  outputRef    String?  @map("output_ref")   // section name, analysis id, message id
  rating       Int                            // 1=wrong, 2=ok, 3=good, 4=excellent
  originalText String   @map("original_text") @db.Text
  correctedText String? @map("corrected_text") @db.Text  // user's edited version
  comment      String?                        // optional free-text note
  learned      Boolean  @default(false)       // true once stored as PROCEDURAL memory
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([agentKey])
  @@index([learned])
  @@index([createdAt])
  @@map("output_feedback")
}

// ─── Pitch Deck Template ───────────────────────────────────────

model PitchDeckTemplate {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String                         // original filename
  pptxBuffer  Bytes    @map("pptx_buffer")  // raw .pptx binary
  themeJson   Json     @map("theme_json")   // extracted colors + fonts
  slotMap     Json     @map("slot_map")     // { exec_summary: 2, financials: 5, ... }
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("pitch_deck_templates")
}
